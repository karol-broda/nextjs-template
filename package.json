{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxlint && tsc --noEmit",
    "types": "tsc --noEmit",
    "format": "oxfmt --write \"**/*.{ts,tsx}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "bash start-database.sh",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "auth:secret": "openssl rand -base64 32",
    "test": "bun test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@elysiajs/eden": "1.4.9",
    "@elysiajs/openapi": "1.4.15",
    "@phosphor-icons/react": "2.1.10",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-form": "1.29.1",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-table": "8.21.3",
    "better-auth": "1.6.9",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.28",
    "evlog": "2.16.0",
    "geist": "1.7.0",
    "nanoid": "5.1.11",
    "neverthrow": "8.2.0",
    "next": "16.2.4",
    "next-safe-action": "8.5.2",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "postcss": "8.5.14",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
